---
// src/pages/dashboard.astro
import Layout from "../layouts/Layout.astro";
---

<Layout title="QorySol - Panel de Control">
  <div
    id="dashboardContent"
    class="space-y-6"
  >
    <!-- ── Encabezado ── -->
    <div
      class="dash-card rounded-2xl p-5 flex flex-col sm:flex-row justify-between items-center gap-4 animate-in"
      style="animation-delay:0.05s"
    >
      <div class="flex items-center gap-4">
        <div
          style="background:rgba(212,160,23,0.12);border:1px solid rgba(212,160,23,0.25)"
          class="p-3 rounded-full"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-7 h-7"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            style="color:#d4a017"
          >
            <path
              d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"
            >
            </path>
            <path
              d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"
              stroke-linecap="round"
            >
            </path>
          </svg>
        </div>
        <div>
          <h2
            class="text-2xl font-bold"
            style="color:#f0e6c8"
          >
            ¡Hola, <span
              id="userFullName"
              style="color:#f5d97a"
            >
              ...
            </span>!
          </h2>
          <p style="color:rgba(212,160,23,0.5);font-size:0.85rem">
            <i
              class="fas fa-chart-line mr-1"
              style="color:#4ade80"
            >
            </i>Potencia tu negocio con QorySol
          </p>
        </div>
      </div>
      <button
        id="logoutBtn"
        class="btn-green px-5 py-2.5 rounded-xl flex items-center gap-2 text-sm"
      >
        <i class="fas fa-sign-out-alt"></i> Cerrar sesión
      </button>
    </div>

    <!-- ── Tarjetas: saldo + asesor ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Saldo -->
      <div
        class="dash-card-gold rounded-2xl p-6 animate-in"
        style="animation-delay:0.1s"
      >
        <div class="flex items-center justify-between">
          <div>
            <p class="label-text mb-2">Saldo de crédito disponible</p>
            <p
              class="text-4xl font-bold"
              style="color:#f5d97a;font-family:'Cinzel',serif"
              id="creditBalanceDisplay"
            >
              S/ 0.00
            </p>
          </div>
          <div
            style="background:rgba(212,160,23,0.1);border:1px solid rgba(212,160,23,0.2)"
            class="p-4 rounded-full"
          >
            <i
              class="fas fa-coins text-3xl"
              style="color:rgba(212,160,23,0.7)"
            >
            </i>
          </div>
        </div>
        <div
          class="mt-4 flex items-center gap-2"
          style="color:rgba(212,160,23,0.5);font-size:0.8rem"
        >
          <i class="fas fa-info-circle"></i>
          <span>Monto pendiente de pago</span>
        </div>
      </div>

      <!-- Asesor -->
      <div
        class="dash-card rounded-2xl p-6 animate-in"
        style="animation-delay:0.15s;border-left:3px solid #d4a017"
      >
        <div class="flex items-center gap-4">
          <div
            style="background:rgba(22,101,52,0.4);border:1px solid rgba(74,222,128,0.2)"
            class="p-3 rounded-full"
          >
            <i
              class="fas fa-user-tie text-2xl"
              style="color:#4ade80"
            >
            </i>
          </div>
          <div>
            <p
              style="color:rgba(212,160,23,0.5);font-size:0.78rem;letter-spacing:0.1em;text-transform:uppercase"
            >
              Tu Asesor Microfinanciero
            </p>
            <p
              class="text-2xl font-bold mt-0.5"
              style="color:#f0e6c8"
              id="advisorName"
            >
              ---
            </p>
          </div>
        </div>
        <div
          class="mt-4 flex items-center gap-2"
          style="color:rgba(74,222,128,0.6);font-size:0.82rem"
        >
          <i class="fas fa-phone-alt"></i>
          <span>Disponible para consultas</span>
        </div>
      </div>
    </div>

    <!-- ── Historial de Préstamos ── -->
    <div
      class="dash-card rounded-2xl overflow-hidden animate-in"
      style="animation-delay:0.2s"
    >
      <div class="dash-header px-6 py-4 flex items-center gap-3">
        <i
          class="fas fa-history"
          style="color:#f5d97a"
        >
        </i>
        <h3
          class="text-lg font-bold"
          style="color:#f5d97a;font-family:'Cinzel',serif"
        >
          Historial de Préstamos
        </h3>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead>
            <tr style="border-bottom:1px solid rgba(212,160,23,0.15)">
              <th class="px-6 py-3 text-left label-text">Monto</th>
              <th class="px-6 py-3 text-left label-text">Fecha</th>
              <th class="px-6 py-3 text-left label-text">Estado</th>
              <th class="px-6 py-3 text-left label-text">Saldo Pendiente</th>
            </tr>
          </thead>
          <tbody id="loansTableBody">
            <tr>
              <td
                colspan="4"
                class="px-6 py-8 text-center"
                style="color:rgba(212,160,23,0.4)"
              >
                Cargando historial...
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ── Simulador ── -->
    <div
      class="dash-card rounded-2xl overflow-hidden animate-in"
      style="animation-delay:0.25s"
    >
      <div class="dash-header px-6 py-4">
        <div class="flex items-center gap-3">
          <i
            class="fas fa-calculator"
            style="color:#f5d97a"
          >
          </i>
          <h3
            class="text-lg font-bold"
            style="color:#f5d97a;font-family:'Cinzel',serif"
          >
            Simulador de Préstamos
          </h3>
        </div>
        <p style="color:rgba(212,160,23,0.45);font-size:0.8rem;margin-top:2px">
          Calcula cuotas personalizadas para tu negocio
        </p>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label class="label-text block mb-2">Monto solicitado (S/)</label>
            <div class="relative">
              <span
                class="absolute left-3 top-1/2 -translate-y-1/2 text-sm"
                style="color:rgba(212,160,23,0.6)"
              >
                S/
              </span>
              <input
                type="number"
                id="loanAmount"
                value="2000"
                step="100"
                placeholder="1000"
                class="input-field w-full pl-8 pr-4 py-2.5 rounded-xl text-sm"
              />
            </div>
          </div>
          <div>
            <label class="label-text block mb-2">Plazo (meses)</label>
            <select
              id="loanTerm"
              class="input-field w-full px-4 py-2.5 rounded-xl text-sm"
            >
              <option value="3">3 meses</option>
              <option
                value="6"
                selected
              >
                6 meses
              </option>
              <option value="9">9 meses</option>
              <option value="12">12 meses</option>
              <option value="18">18 meses</option>
            </select>
          </div>
          <div>
            <label class="label-text block mb-2">
              Tasa interés mensual (%)
            </label>
            <input
              type="number"
              id="interestRate"
              value="2.5"
              step="0.1"
              min="0"
              class="input-field w-full px-4 py-2.5 rounded-xl text-sm"
            />
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-4 items-center justify-between">
          <button
            id="simulateBtn"
            class="btn-gold px-6 py-2.5 rounded-xl text-sm flex items-center gap-2"
          >
            <i class="fas fa-chart-bar"></i> Simular préstamo
          </button>
          <div
            id="simulationResult"
            class="sim-result p-3 rounded-xl flex-1 text-center text-sm"
            style="color:rgba(212,160,23,0.5)"
          >
            Resultado aparecerá aquí
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    interface Loan {
      id: number;
      amount: number;
      date: string;
      status: string;
      remaining: number;
    }
    interface UserData {
      dni: string;
      fullName: string;
      creditBalance: number;
      advisor: string;
      loans: Loan[];
    }

    function redirectToLogin(): void {
      window.location.href = "/";
    }

    function loadUserData(): UserData | null {
      const stored = sessionStorage.getItem("currentUser");
      if (!stored) {
        redirectToLogin();
        return null;
      }
      try {
        const user = JSON.parse(stored) as UserData;
        if (!user.dni) throw new Error("invalid");
        return user;
      } catch {
        redirectToLogin();
        return null;
      }
    }

    function renderLoans(loans: Loan[]): void {
      const tbody = document.getElementById("loansTableBody") as HTMLElement;
      if (!loans || loans.length === 0) {
        tbody.innerHTML =
          '<tr><td colspan="4" class="px-6 py-8 text-center" style="color:rgba(212,160,23,0.4)">No hay préstamos registrados</td></tr>';
        return;
      }
      tbody.innerHTML = loans
        .map(
          (loan) => `
        <tr class="table-row-hover transition" style="border-bottom:1px solid rgba(212,160,23,0.08)">
          <td class="px-6 py-4 font-medium" style="color:#f0e6c8">S/ ${loan.amount.toFixed(2)}</td>
          <td class="px-6 py-4" style="color:rgba(240,230,200,0.7)">${loan.date}</td>
          <td class="px-6 py-4">
            <span class="px-2.5 py-1 rounded-full text-xs font-semibold ${loan.status === "Activo" ? "badge-activo" : "badge-pagado"}">
              ${loan.status}
            </span>
          </td>
          <td class="px-6 py-4" style="color:rgba(240,230,200,0.7)">${loan.remaining > 0 ? `S/ ${loan.remaining.toFixed(2)}` : "—"}</td>
        </tr>
      `,
        )
        .join("");
    }

    function updateDashboard(user: UserData): void {
      const nameEl = document.getElementById("userFullName") as HTMLElement;
      const balanceEl = document.getElementById(
        "creditBalanceDisplay",
      ) as HTMLElement;
      const advisorEl = document.getElementById("advisorName") as HTMLElement;
      nameEl.innerText = user.fullName || "Inversor";
      balanceEl.innerHTML = `S/ ${user.creditBalance?.toFixed(2) ?? "0.00"}`;
      advisorEl.innerText = user.advisor || "Asignado próximamente";
      renderLoans(user.loans || []);
    }

    interface SimResult {
      monthlyPayment: number;
      totalPayment: number;
      totalInterest: number;
    }
    function simulateLoan(
      amount: number,
      months: number,
      rate: number,
    ): SimResult {
      const r = rate / 100;
      if (r === 0)
        return {
          monthlyPayment: amount / months,
          totalPayment: amount,
          totalInterest: 0,
        };
      const mp =
        (amount * r * Math.pow(1 + r, months)) / (Math.pow(1 + r, months) - 1);
      return {
        monthlyPayment: mp,
        totalPayment: mp * months,
        totalInterest: mp * months - amount,
      };
    }

    function setupSimulator(): void {
      const btn = document.getElementById("simulateBtn") as HTMLButtonElement;
      const amountEl = document.getElementById(
        "loanAmount",
      ) as HTMLInputElement;
      const termEl = document.getElementById("loanTerm") as HTMLSelectElement;
      const rateEl = document.getElementById(
        "interestRate",
      ) as HTMLInputElement;
      const resultEl = document.getElementById(
        "simulationResult",
      ) as HTMLElement;
      if (!btn || !amountEl || !termEl || !rateEl || !resultEl) return;

      function run(): void {
        const amount = parseFloat(amountEl.value);
        const months = parseInt(termEl.value);
        let rate = parseFloat(rateEl.value);
        if (isNaN(amount) || amount <= 0) {
          resultEl.innerHTML =
            '<span style="color:#fca5a5">Monto inválido</span>';
          return;
        }
        if (isNaN(rate) || rate < 0) rate = 0;
        const { monthlyPayment, totalPayment, totalInterest } = simulateLoan(
          amount,
          months,
          rate,
        );
        resultEl.innerHTML = `
          <div class="text-sm space-y-1" style="color:#f0e6c8;text-align:left">
            <div><span style="color:#f5d97a;font-weight:600">Cuota mensual:</span> S/ ${monthlyPayment.toFixed(2)}</div>
            <div><span style="color:#f5d97a;font-weight:600">Total a pagar:</span> S/ ${totalPayment.toFixed(2)}</div>
            <div><span style="color:#f5d97a;font-weight:600">Interés total:</span> S/ ${totalInterest.toFixed(2)}</div>
          </div>`;
      }
      btn.addEventListener("click", run);
      amountEl.addEventListener("input", run);
      termEl.addEventListener("change", run);
      rateEl.addEventListener("input", run);
      run();
    }

    function setupLogout(): void {
      const btn = document.getElementById("logoutBtn") as HTMLButtonElement;
      btn.addEventListener("click", () => {
        sessionStorage.removeItem("currentUser");
        redirectToLogin();
      });
    }

    const user = loadUserData();
    if (user) {
      updateDashboard(user);
      setupSimulator();
      setupLogout();
    }
  </script>
</Layout>
