---
// src/pages/dashboard.astro
import Layout from "../layouts/Layout.astro";
---

<Layout title="QorySol - Panel de Control">
  <div
    id="dashboardContent"
    class="space-y-6"
  >
    <!-- Encabezado con bienvenida y logout -->
    <div
      class="flex flex-col sm:flex-row justify-between items-center bg-white rounded-xl shadow-md p-5"
    >
      <div class="flex items-center gap-3">
        <div class="bg-emerald-100 p-3 rounded-full">
          <i class="fas fa-hand-holding-usd text-emerald-700 text-2xl"></i>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-gray-800">
            ¡Hola, <span id="userFullName">...</span>!
          </h2>
          <p class="text-gray-500">
            <i class="fas fa-chart-line text-emerald-500 mr-1"></i>Potencia tu
            negocio con QorySol
          </p>
        </div>
      </div>
      <button
        id="logoutBtn"
        class="mt-3 sm:mt-0 bg-red-100 hover:bg-red-200 text-red-700 px-5 py-2 rounded-full transition flex items-center gap-2"
      >
        <i class="fas fa-sign-out-alt"></i> Cerrar sesión
      </button>
    </div>

    <!-- Tarjetas resumen: saldo crédito + asesor -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div
        class="bg-linear-to-br from-emerald-600 to-teal-700 rounded-xl shadow-lg p-6 text-white"
      >
        <div class="flex items-center justify-between">
          <div>
            <p class="text-emerald-100 text-sm uppercase tracking-wide">
              Saldo de crédito disponible
            </p>
            <p
              class="text-4xl font-bold mt-2"
              id="creditBalanceDisplay"
            >
              S/ 0.00
            </p>
          </div>
          <i class="fas fa-coins text-5xl text-emerald-200 opacity-80"></i>
        </div>
        <div class="mt-4 text-emerald-100 text-sm">
          <i class="fas fa-info-circle mr-1"></i> Monto pendiente de pago
        </div>
      </div>
      <div
        class="bg-white rounded-xl shadow-lg p-6 border-l-8 border-emerald-500"
      >
        <div class="flex items-center gap-4">
          <div class="bg-emerald-100 p-3 rounded-full">
            <i class="fas fa-user-tie text-emerald-700 text-2xl"></i>
          </div>
          <div>
            <p class="text-gray-500 text-sm">Tu Asesor Microfinanciero</p>
            <p
              class="text-2xl font-bold text-gray-800"
              id="advisorName"
            >
              ---
            </p>
          </div>
        </div>
        <div class="mt-3 text-gray-600 text-sm">
          <i class="fas fa-phone-alt mr-1 text-emerald-500"></i> Disponible para consultas
        </div>
      </div>
    </div>

    <!-- Historial de Préstamos -->
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
      <div class="bg-gray-50 px-6 py-4 border-b">
        <h3 class="text-xl font-bold text-gray-800">
          <i class="fas fa-history text-emerald-600 mr-2"></i>Historial de
          Préstamos
        </h3>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th
                class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"
              >
                Monto
              </th>
              <th
                class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"
              >
                Fecha
              </th>
              <th
                class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"
              >
                Estado
              </th>
              <th
                class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"
              >
                Saldo Pendiente
              </th>
            </tr>
          </thead>
          <tbody
            id="loansTableBody"
            class="bg-white divide-y divide-gray-100"
          >
            <tr>
              <td
                colspan="4"
                class="px-6 py-8 text-center text-gray-400"
              >
                Cargando historial...
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Simulador de Préstamos -->
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
      <div class="bg-gray-50 px-6 py-4 border-b">
        <h3 class="text-xl font-bold text-gray-800">
          <i class="fas fa-calculator text-emerald-600 mr-2"></i>Simulador de
          Préstamos
        </h3>
        <p class="text-gray-500 text-sm">
          Calcula cuotas personalizadas para tu negocio
        </p>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Monto solicitado (S/)
            </label>
            <div class="relative">
              <span class="absolute left-3 top-3 text-gray-400">S/</span>
              <input
                type="number"
                id="loanAmount"
                class="pl-8 w-full border border-gray-300 rounded-lg p-2 focus:ring-emerald-500"
                placeholder="1000"
                value="2000"
                step="100"
              />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Plazo (meses)
            </label>
            <select
              id="loanTerm"
              class="w-full border border-gray-300 rounded-lg p-2 focus:ring-emerald-500"
            >
              <option value="3">3 meses</option>
              <option
                value="6"
                selected
              >
                6 meses
              </option>
              <option value="9">9 meses</option>
              <option value="12">12 meses</option>
              <option value="18">18 meses</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Tasa interés mensual (%)
            </label>
            <input
              type="number"
              id="interestRate"
              class="w-full border border-gray-300 rounded-lg p-2 focus:ring-emerald-500"
              value="2.5"
              step="0.1"
              min="0"
            />
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-4 items-center justify-between">
          <button
            id="simulateBtn"
            class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 px-6 rounded-lg transition shadow flex items-center gap-2"
          >
            <i class="fas fa-chart-simple"></i> Simular préstamo
          </button>
          <div
            id="simulationResult"
            class="bg-emerald-50 p-3 rounded-lg flex-1 text-center"
          >
            <span class="text-gray-600">Resultado aparecerá aquí</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    interface Loan {
      id: number;
      amount: number;
      date: string;
      status: string;
      remaining: number;
    }

    interface UserData {
      dni: string;
      fullName: string;
      creditBalance: number;
      advisor: string;
      loans: Loan[];
    }

    function redirectToLogin(): void {
      window.location.href = "/";
    }

    function loadUserData(): UserData | null {
      const storedUser = sessionStorage.getItem("currentUser");
      if (!storedUser) {
        redirectToLogin();
        return null;
      }
      try {
        const user = JSON.parse(storedUser) as UserData;
        if (!user.dni) throw new Error("Datos inválidos");
        return user;
      } catch (e) {
        redirectToLogin();
        return null;
      }
    }

    function renderLoans(loans: Loan[]): void {
      const tbody = document.getElementById("loansTableBody");
      if (!tbody) return;

      if (!loans || loans.length === 0) {
        tbody.innerHTML =
          '<tr><td colspan="4" class="px-6 py-8 text-center text-gray-400">No hay préstamos registrados</td></tr>';
        return;
      }
      tbody.innerHTML = loans
        .map(
          (loan) => `
      <tr class="hover:bg-gray-50 transition">
        <td class="px-6 py-4 font-medium">S/ ${loan.amount.toFixed(2)}</td>
        <td class="px-6 py-4">${loan.date}</td>
        <td class="px-6 py-4">
          <span class="px-2 py-1 rounded-full text-xs font-semibold ${loan.status === "Activo" ? "bg-yellow-100 text-yellow-700" : "bg-green-100 text-green-700"}">
            ${loan.status}
          </span>
        </td>
        <td class="px-6 py-4">${loan.remaining > 0 ? `S/ ${loan.remaining.toFixed(2)}` : "-"}</td>
      </tr>
    `,
        )
        .join("");
    }

    function updateDashboard(user: UserData): void {
      const nameEl = document.getElementById("userFullName");
      const balanceEl = document.getElementById("creditBalanceDisplay");
      const advisorEl = document.getElementById("advisorName");

      if (nameEl) nameEl.innerText = user.fullName || "Inversor";
      if (balanceEl)
        balanceEl.innerHTML = `S/ ${user.creditBalance?.toFixed(2) ?? "0.00"}`;
      if (advisorEl)
        advisorEl.innerText = user.advisor || "Asignado próximamente";

      renderLoans(user.loans || []);
    }

    interface SimulationResult {
      monthlyPayment: number;
      totalPayment: number;
      totalInterest: number;
    }

    function simulateLoan(
      amount: number,
      months: number,
      monthlyRatePercent: number,
    ): SimulationResult {
      const monthlyRate = monthlyRatePercent / 100;
      if (monthlyRate === 0) {
        const monthlyPayment = amount / months;
        return { monthlyPayment, totalPayment: amount, totalInterest: 0 };
      }
      const denominator = Math.pow(1 + monthlyRate, months) - 1;
      const monthlyPayment =
        (amount * monthlyRate * Math.pow(1 + monthlyRate, months)) /
        denominator;
      const totalPayment = monthlyPayment * months;
      const totalInterest = totalPayment - amount;
      return { monthlyPayment, totalPayment, totalInterest };
    }

    function setupSimulator(): void {
      const simulateBtn = document.getElementById("simulateBtn");
      const amountInput = document.getElementById(
        "loanAmount",
      ) as HTMLInputElement | null;
      const termSelect = document.getElementById(
        "loanTerm",
      ) as HTMLSelectElement | null;
      const rateInput = document.getElementById(
        "interestRate",
      ) as HTMLInputElement | null;
      const resultDiv = document.getElementById("simulationResult");

      if (
        !simulateBtn ||
        !amountInput ||
        !termSelect ||
        !rateInput ||
        !resultDiv
      )
        return;

      function performSimulation(): void {
        if (!amountInput || !termSelect || !rateInput || !resultDiv) return;

        let amount = parseFloat(amountInput.value);
        const months = parseInt(termSelect.value);
        let rate = parseFloat(rateInput.value);

        if (isNaN(amount) || amount <= 0) {
          resultDiv.innerHTML =
            '<span class="text-red-600"><i class="fas fa-exclamation-triangle"></i> Monto inválido</span>';
          return;
        }
        if (isNaN(rate) || rate < 0) rate = 0;
        if (months <= 0) return;

        const { monthlyPayment, totalPayment, totalInterest } = simulateLoan(
          amount,
          months,
          rate,
        );
        resultDiv.innerHTML = `
        <div class="text-sm space-y-1">
          <div><span class="font-semibold">Cuota mensual:</span> S/ ${monthlyPayment.toFixed(2)}</div>
          <div><span class="font-semibold">Total a pagar:</span> S/ ${totalPayment.toFixed(2)}</div>
          <div><span class="font-semibold">Interés total:</span> S/ ${totalInterest.toFixed(2)}</div>
        </div>
      `;
      }

      simulateBtn.addEventListener("click", performSimulation);
      amountInput.addEventListener("input", performSimulation);
      termSelect.addEventListener("change", performSimulation);
      rateInput.addEventListener("input", performSimulation);
      performSimulation();
    }

    function setupLogout(): void {
      const logoutBtn = document.getElementById("logoutBtn");
      if (logoutBtn) {
        logoutBtn.addEventListener("click", () => {
          sessionStorage.removeItem("currentUser");
          redirectToLogin();
        });
      }
    }

    const user = loadUserData();
    if (user) {
      updateDashboard(user);
      setupSimulator();
      setupLogout();
    }
  </script>
</Layout>
