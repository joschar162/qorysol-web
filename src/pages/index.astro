---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
---

<Layout title="QorySol — Ingresar">
  <!-- Partículas -->
  <div
    class="particle particle-gold"
    style="width:220px;height:220px;top:3%;left:3%;--dur:11s;--delay:0s;"
  >
  </div>
  <div
    class="particle particle-green"
    style="width:180px;height:180px;top:60%;right:4%;--dur:9s;--delay:1.5s;"
  >
  </div>
  <div
    class="particle particle-gold"
    style="width:90px;height:90px;top:35%;left:75%;--dur:13s;--delay:3s;"
  >
  </div>
  <div
    class="particle particle-green"
    style="width:60px;height:60px;bottom:10%;left:15%;--dur:7s;--delay:2s;"
  >
  </div>

  <div
    class="relative z-10 flex flex-col items-center justify-center min-h-[calc(100vh-4rem)] p-4"
  >
    <div
      class="card-glass rounded-2xl w-full max-w-sm sm:max-w-md animate-in"
      style="animation-delay:0.05s"
    >
      <div class="corner-tl"></div>
      <div class="corner-br"></div>

      <!-- Header -->
      <div class="pt-10 pb-7 px-8 sm:px-10 text-center">
        <div
          class="flex justify-center mb-4 animate-in"
          style="animation-delay:0.15s"
        >
          <img
            src="data:image/png;base64,"
            alt="QorySol"
            class="logo-img h-20 sm:h-24 w-auto object-contain"
          />
        </div>
        <h1
          class="title-brand text-3xl sm:text-4xl font-bold animate-in"
          style="animation-delay:0.25s"
        >
          QorySol
        </h1>
        <p
          class="subtitle mt-2 animate-in"
          style="animation-delay:0.32s"
        >
          Potencia tu negocio
        </p>
        <div
          class="divider-gold h-px mt-6 mx-auto w-3/4 animate-in"
          style="animation-delay:0.38s"
        >
        </div>
      </div>

      <!-- Form -->
      <div class="px-8 sm:px-10 pb-10">
        <form
          id="loginForm"
          novalidate
          class="space-y-5"
        >
          <!-- DNI -->
          <div
            class="animate-in"
            style="animation-delay:0.44s"
          >
            <label
              for="dni"
              class="label-text block mb-2"
            >
              DNI (usuario)
            </label>
            <div class="relative">
              <span
                class="icon-gold absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <rect
                    x="3"
                    y="4"
                    width="18"
                    height="16"
                    rx="2"
                    stroke="currentColor"
                    fill="none"
                  >
                  </rect>
                  <circle
                    cx="9"
                    cy="10"
                    r="2"
                    stroke="currentColor"
                    fill="none"
                  >
                  </circle>
                  <path
                    d="M6 15c0-1.5 1.3-2.5 3-2.5s3 1 3 2.5"
                    stroke="currentColor"
                  >
                  </path>
                  <path
                    d="M15 9h3M15 12h2"
                    stroke="currentColor"
                    stroke-linecap="round"
                  >
                  </path>
                </svg>
              </span>
              <input
                type="text"
                id="dni"
                name="dni"
                required
                placeholder="Ingrese su DNI"
                maxlength="8"
                pattern="[0-9]{8}"
                inputmode="numeric"
                class="input-field w-full pl-11 pr-4 py-3.5 rounded-xl text-sm"
              />
            </div>
          </div>

          <!-- Contraseña -->
          <div
            class="animate-in"
            style="animation-delay:0.50s"
          >
            <label
              for="password"
              class="label-text block mb-2"
            >
              Contraseña (4 dígitos)
            </label>
            <div class="relative">
              <span
                class="icon-gold absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <rect
                    x="5"
                    y="11"
                    width="14"
                    height="10"
                    rx="2"
                    stroke="currentColor"
                    fill="none"
                  >
                  </rect>
                  <path
                    d="M8 11V7a4 4 0 118 0v4"
                    stroke="currentColor"
                    stroke-linecap="round"
                  >
                  </path>
                </svg>
              </span>
              <input
                type="password"
                id="password"
                name="password"
                required
                placeholder="••••"
                maxlength="4"
                pattern="[0-9]{4}"
                inputmode="numeric"
                class="input-field w-full pl-11 pr-12 py-3.5 rounded-xl text-sm tracking-widest"
              />
              <button
                type="button"
                id="togglePass"
                tabindex="-1"
                class="icon-gold absolute right-4 top-1/2 -translate-y-1/2 hover:opacity-80 transition-opacity"
              >
                <svg
                  id="eyeIcon"
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                    stroke="currentColor"
                  >
                  </path>
                  <circle
                    cx="12"
                    cy="12"
                    r="3"
                    stroke="currentColor"
                  >
                  </circle>
                </svg>
              </button>
            </div>
          </div>

          <!-- Error -->
          <div
            id="errorMessage"
            class="error-box hidden rounded-lg px-4 py-2.5 items-center gap-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"
              >
              </path>
              <line
                x1="12"
                y1="9"
                x2="12"
                y2="13"
              >
              </line><line
                x1="12"
                y1="17"
                x2="12.01"
                y2="17"
              >
              </line>
            </svg>
            <span id="errorText">DNI o contraseña incorrectos.</span>
          </div>

          <!-- Botón -->
          <div
            class="animate-in pt-1"
            style="animation-delay:0.56s"
          >
            <button
              type="submit"
              id="submitBtn"
              class="btn-gold w-full py-4 rounded-xl text-sm flex items-center justify-center gap-2.5"
            >
              <svg
                id="btnIcon"
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                </path>
                <polyline
                  points="10 17 15 12 10 7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                </polyline>
                <line
                  x1="15"
                  y1="12"
                  x2="3"
                  y2="12"
                  stroke-linecap="round"
                >
                </line>
              </svg>
              <span id="btnText">Ingresar</span>
            </button>
          </div>
        </form>

        <!-- Demo badge -->
        <div
          class="demo-badge mt-5 rounded-lg px-4 py-2.5 flex items-center gap-2.5 animate-in"
          style="animation-delay:0.62s"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3.5 h-3.5 shrink-0 icon-gold"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
          <span>
            Demo: DNI <strong style="color:rgba(212,160,23,0.8)">
              12345678
            </strong> · contraseña <strong style="color:rgba(212,160,23,0.8)">
              1234
            </strong>
          </span>
        </div>
      </div>
    </div>
  </div>

  <script>
    interface UserData {
      password: string;
      fullName: string;
      creditBalance: number;
      advisor: string;
      loans: {
        id: number;
        amount: number;
        date: string;
        status: string;
        remaining: number;
      }[];
    }

    const usersData: Record<string, UserData> = {
      "12345678": {
        password: "1234",
        fullName: "Ana Gómez",
        creditBalance: 1250.0,
        advisor: "Laura Fernández",
        loans: [
          {
            id: 1,
            amount: 500,
            date: "2023-01-10",
            status: "Pagado",
            remaining: 0,
          },
          {
            id: 2,
            amount: 800,
            date: "2023-06-15",
            status: "Pagado",
            remaining: 0,
          },
          {
            id: 3,
            amount: 1200,
            date: "2024-02-20",
            status: "Activo",
            remaining: 950,
          },
        ],
      },
      "87654321": {
        password: "4321",
        fullName: "Carlos Ruiz",
        creditBalance: 3200.0,
        advisor: "Miguel Vargas",
        loans: [
          {
            id: 1,
            amount: 2000,
            date: "2023-11-01",
            status: "Activo",
            remaining: 1500,
          },
          {
            id: 2,
            amount: 500,
            date: "2024-01-20",
            status: "Pagado",
            remaining: 0,
          },
        ],
      },
      "11111111": {
        password: "0000",
        fullName: "Rosa Mendoza",
        creditBalance: 500.0,
        advisor: "Laura Fernández",
        loans: [
          {
            id: 1,
            amount: 300,
            date: "2024-03-05",
            status: "Activo",
            remaining: 300,
          },
        ],
      },
    };

    const loginForm = document.getElementById("loginForm") as HTMLFormElement;
    const errorDiv = document.getElementById("errorMessage") as HTMLElement;
    const errorText = document.getElementById("errorText") as HTMLElement;
    const btnText = document.getElementById("btnText") as HTMLElement;
    const btnIcon = document.getElementById("btnIcon") as HTMLElement;
    const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement;
    const togglePass = document.getElementById(
      "togglePass",
    ) as HTMLButtonElement;
    const passInput = document.getElementById("password") as HTMLInputElement;
    const dniInput = document.getElementById("dni") as HTMLInputElement;
    const eyeIcon = document.getElementById("eyeIcon") as HTMLElement;

    togglePass.addEventListener("click", () => {
      const show = passInput.type === "password";
      passInput.type = show ? "text" : "password";
      eyeIcon.innerHTML = show
        ? `<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24" stroke="currentColor" stroke-linecap="round"/><line x1="1" y1="1" x2="23" y2="23" stroke="currentColor" stroke-linecap="round"/>`
        : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor"/><circle cx="12" cy="12" r="3" stroke="currentColor"/>`;
    });

    dniInput.addEventListener("input", () => {
      dniInput.value = dniInput.value.replace(/\D/g, "").slice(0, 8);
    });
    passInput.addEventListener("input", () => {
      passInput.value = passInput.value.replace(/\D/g, "").slice(0, 4);
    });

    loginForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const dni = dniInput.value.trim();
      const password = passInput.value;
      submitBtn.disabled = true;
      btnText.textContent = "Verificando...";
      btnIcon.innerHTML = `<path d="M12 2a10 10 0 100 20A10 10 0 0012 2z" stroke="currentColor" opacity="0.2"/><path d="M12 2a10 10 0 0110 10" stroke="currentColor" stroke-linecap="round"><animateTransform attributeName="transform" type="rotate" dur="0.7s" from="0 12 12" to="360 12 12" repeatCount="indefinite"/></path>`;
      errorDiv.classList.add("visible"); // mostrar
      errorDiv.classList.remove("visible"); // ocultar

      setTimeout(() => {
        const user = usersData[dni];
        if (user && user.password === password) {
          btnText.textContent = "✓ Bienvenido";
          submitBtn.style.background =
            "linear-gradient(135deg,#14532d,#16a34a)";
          submitBtn.style.color = "#f5d97a";
          btnIcon.innerHTML = "";
          sessionStorage.setItem(
            "currentUser",
            JSON.stringify({
              dni,
              fullName: user.fullName,
              creditBalance: user.creditBalance,
              advisor: user.advisor,
              loans: user.loans,
            }),
          );
          setTimeout(() => {
            window.location.href = "/dashboard";
          }, 600);
        } else {
          submitBtn.disabled = false;
          btnText.textContent = "Ingresar";
          btnIcon.innerHTML = `<path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4" stroke-linecap="round" stroke-linejoin="round"/><polyline points="10 17 15 12 10 7" stroke-linecap="round" stroke-linejoin="round"/><line x1="15" y1="12" x2="3" y2="12" stroke-linecap="round"/>`;
          errorDiv.classList.remove("hidden");
          errorText.textContent =
            "DNI o contraseña incorrectos. Intente nuevamente.";
          loginForm.classList.add("shake");
          setTimeout(() => {
            loginForm.classList.remove("shake");
            errorDiv.classList.add("hidden");
          }, 3000);
        }
      }, 900);
    });
  </script>
</Layout>
