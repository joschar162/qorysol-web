---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
---

<Layout title="QorySol - Acceso a tu cuenta">
  <div class="flex flex-col items-center justify-center min-h-[80vh]">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="bg-emerald-700 px-6 py-8 text-center">
        <div class="flex justify-center mb-3">
          <i class="fas fa-chart-line text-5xl text-white"></i>
        </div>
        <h1 class="text-3xl font-bold text-white">QorySol</h1>
        <p class="text-emerald-100 mt-2">Potencia tu negocio</p>
      </div>
      <div class="p-6 sm:p-8">
        <form
          id="loginForm"
          class="space-y-6"
        >
          <div>
            <label
              for="dni"
              class="block text-sm font-medium text-gray-700 mb-1"
            >
              DNI (usuario)
            </label>
            <div class="relative">
              <div
                class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"
              >
                <i class="fas fa-id-card text-gray-400"></i>
              </div>
              <input
                type="text"
                id="dni"
                name="dni"
                required
                class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2
                focus:ring-emerald-500 focus:border-emerald-500 transition"
                placeholder="Ingrese su DNI"
                maxlength="8"
                pattern="[0-9]{8}"
              />
            </div>
          </div>
          <div>
            <label
              for="password"
              class="block text-sm font-medium text-gray-700 mb-1"
            >
              Contraseña (4 dígitos)
            </label>
            <div class="relative">
              <div
                class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"
              >
                <i class="fas fa-lock text-gray-400"></i>
              </div>
              <input
                type="password"
                id="password"
                name="password"
                required
                class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition"
                placeholder="••••"
                maxlength="4"
                pattern="[0-9]{4}"
              />
            </div>
          </div>
          <button
            type="submit"
            class="w-full bg-green-600 hover:bg-emerald-700 text-white font-bold py-3 px-4 rounded-xl transition duration-200 transform hover:scale-[1.02] shadow-md"
          >
            <i class="fas fa-sign-in-alt mr-2"></i> Ingresar
          </button>
        </form>
        <div
          id="errorMessage"
          class="mt-4 text-center text-red-600 text-sm hidden bg-red-50 p-2 rounded-lg"
        >
        </div>
      </div>
    </div>
    <div class="mt-8 text-center text-gray-600 text-sm">
      <i class="fas fa-shield-alt mr-1"></i> Demostración: DNI 12345678 · contraseña
      1234
    </div>
  </div>

  <script>
    interface UserData {
      password: string;
      fullName: string;
      creditBalance: number;
      advisor: string;
      loans: {
        id: number;
        amount: number;
        date: string;
        status: string;
        remaining: number;
      }[];
    }

    const usersData: Record<string, UserData> = {
      "12345678": {
        password: "1234",
        fullName: "Ana Gómez",
        creditBalance: 1250.0,
        advisor: "Laura Fernández",
        loans: [
          {
            id: 1,
            amount: 500,
            date: "2023-01-10",
            status: "Pagado",
            remaining: 0,
          },
          {
            id: 2,
            amount: 800,
            date: "2023-06-15",
            status: "Pagado",
            remaining: 0,
          },
          {
            id: 3,
            amount: 1200,
            date: "2024-02-20",
            status: "Activo",
            remaining: 950,
          },
        ],
      },
      "87654321": {
        password: "4321",
        fullName: "Carlos Ruiz",
        creditBalance: 3200.0,
        advisor: "Miguel Vargas",
        loans: [
          {
            id: 1,
            amount: 2000,
            date: "2023-11-01",
            status: "Activo",
            remaining: 1500,
          },
          {
            id: 2,
            amount: 500,
            date: "2024-01-20",
            status: "Pagado",
            remaining: 0,
          },
        ],
      },
      "11111111": {
        password: "0000",
        fullName: "Rosa Mendoza",
        creditBalance: 500.0,
        advisor: "Laura Fernández",
        loans: [
          {
            id: 1,
            amount: 300,
            date: "2024-03-05",
            status: "Activo",
            remaining: 300,
          },
        ],
      },
    };

    const loginForm = document.getElementById(
      "loginForm",
    ) as HTMLFormElement | null;
    const errorDiv = document.getElementById(
      "errorMessage",
    ) as HTMLElement | null;

    loginForm?.addEventListener("submit", (e) => {
      e.preventDefault();
      const dni = (
        document.getElementById("dni") as HTMLInputElement
      ).value.trim();
      const password = (document.getElementById("password") as HTMLInputElement)
        .value;

      const user = usersData[dni];
      if (user && user.password === password) {
        const userToStore = {
          dni,
          fullName: user.fullName,
          creditBalance: user.creditBalance,
          advisor: user.advisor,
          loans: user.loans,
        };
        sessionStorage.setItem("currentUser", JSON.stringify(userToStore));
        window.location.href = "/dashboard";
      } else {
        if (errorDiv) {
          errorDiv.classList.remove("hidden");
          errorDiv.innerHTML =
            '<i class="fas fa-exclamation-triangle mr-1"></i> DNI o contraseña incorrectos. Intente nuevamente.';
          setTimeout(() => errorDiv.classList.add("hidden"), 3000);
        }
      }
    });
  </script>
</Layout>
