---
// QorySol Login Page - Astro Component
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <title>QorySol — Ingresar</title>

    <style>
      @import url("https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Raleway:wght@300;400;500;600&display=swap");

      * {
        box-sizing: border-box;
      }

      body {
        font-family: "Raleway", sans-serif;
        background: radial-gradient(
          ellipse at 30% 20%,
          #1c1408 0%,
          #0a0a0a 60%,
          #050505 100%
        );
        min-height: 100vh;
        overflow: hidden;
      }

      /* Partículas decorativas */
      .particle {
        position: absolute;
        border-radius: 50%;
        background: radial-gradient(
          circle,
          rgba(212, 160, 23, 0.6) 0%,
          transparent 70%
        );
        animation: float var(--dur, 8s) ease-in-out infinite;
        animation-delay: var(--delay, 0s);
        pointer-events: none;
      }

      @keyframes float {
        0%,
        100% {
          transform: translateY(0px) scale(1);
          opacity: 0.3;
        }
        50% {
          transform: translateY(-20px) scale(1.1);
          opacity: 0.7;
        }
      }

      .card-glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 160, 23, 0.2);
        box-shadow:
          0 0 0 1px rgba(212, 160, 23, 0.05),
          0 25px 60px rgba(0, 0, 0, 0.8),
          inset 0 1px 0 rgba(255, 255, 255, 0.05);
      }

      .logo-img {
        filter: drop-shadow(0 0 12px rgba(212, 160, 23, 0.6));
        animation: shimmer 3s ease-in-out infinite;
      }

      @keyframes shimmer {
        0%,
        100% {
          filter: drop-shadow(0 0 8px rgba(212, 160, 23, 0.4));
        }
        50% {
          filter: drop-shadow(0 0 20px rgba(212, 160, 23, 0.9));
        }
      }

      .input-field {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(212, 160, 23, 0.2);
        color: #f0e6c8;
        transition: all 0.3s ease;
        font-family: "Raleway", sans-serif;
      }

      .input-field::placeholder {
        color: rgba(212, 160, 23, 0.3);
      }

      .input-field:focus {
        outline: none;
        border-color: rgba(212, 160, 23, 0.7);
        background: rgba(212, 160, 23, 0.05);
        box-shadow:
          0 0 0 3px rgba(212, 160, 23, 0.1),
          0 0 20px rgba(212, 160, 23, 0.1);
      }

      .btn-login {
        background: linear-gradient(
          135deg,
          #b8860b 0%,
          #d4a017 35%,
          #f5d97a 50%,
          #d4a017 65%,
          #9a6f0a 100%
        );
        background-size: 200% 200%;
        color: #1a0e00;
        font-family: "Cinzel", serif;
        font-weight: 700;
        letter-spacing: 0.1em;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }

      .btn-login::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          transparent 0%,
          rgba(255, 255, 255, 0.15) 50%,
          transparent 100%
        );
        transform: translateX(-100%);
        transition: transform 0.5s ease;
      }

      .btn-login:hover::before {
        transform: translateX(100%);
      }

      .btn-login:hover {
        background-position: right center;
        box-shadow:
          0 0 25px rgba(212, 160, 23, 0.5),
          0 8px 25px rgba(0, 0, 0, 0.5);
        transform: translateY(-1px);
      }

      .btn-login:active {
        transform: translateY(0);
      }

      .label-text {
        font-family: "Cinzel", serif;
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        color: rgba(212, 160, 23, 0.7);
        text-transform: uppercase;
      }

      .title-brand {
        font-family: "Cinzel", serif;
        background: linear-gradient(135deg, #d4a017, #f5d97a, #b8860b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .subtitle {
        font-family: "Raleway", sans-serif;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: rgba(212, 160, 23, 0.45);
      }

      .divider-line {
        background: linear-gradient(
          to right,
          transparent,
          rgba(212, 160, 23, 0.4),
          transparent
        );
      }

      .demo-badge {
        background: rgba(212, 160, 23, 0.08);
        border: 1px solid rgba(212, 160, 23, 0.15);
        color: rgba(212, 160, 23, 0.5);
        font-family: "Raleway", sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
      }

      .icon-wrap {
        color: rgba(212, 160, 23, 0.5);
      }

      .animate-in {
        opacity: 0;
        animation: fadeUp 0.7s ease forwards;
      }

      @keyframes fadeUp {
        to {
          opacity: 1;
          transform: translateY(0);
        }
        from {
          opacity: 0;
          transform: translateY(24px);
        }
      }

      /* Horizontal decorative lines */
      .corner-tl,
      .corner-br {
        position: absolute;
        width: 40px;
        height: 40px;
        opacity: 0.4;
      }
      .corner-tl {
        top: 16px;
        left: 16px;
        border-top: 1px solid #d4a017;
        border-left: 1px solid #d4a017;
      }
      .corner-br {
        bottom: 16px;
        right: 16px;
        border-bottom: 1px solid #d4a017;
        border-right: 1px solid #d4a017;
      }

      /* Error shake animation */
      @keyframes shake {
        0%,
        100% {
          transform: translateX(0);
        }
        20%,
        60% {
          transform: translateX(-6px);
        }
        40%,
        80% {
          transform: translateX(6px);
        }
      }
      .shake {
        animation: shake 0.4s ease;
      }
    </style>
  </head>
  <body class="flex items-center justify-center min-h-screen p-4">
    <!-- Partículas decorativas -->
    <div
      class="particle"
      style="width:200px;height:200px;top:5%;left:5%;--dur:10s;--delay:0s;"
    >
    </div>
    <div
      class="particle"
      style="width:120px;height:120px;top:70%;right:8%;--dur:8s;--delay:2s;"
    >
    </div>
    <div
      class="particle"
      style="width:80px;height:80px;top:40%;left:80%;--dur:12s;--delay:4s;"
    >
    </div>
    <div
      class="particle"
      style="width:60px;height:60px;bottom:10%;left:20%;--dur:7s;--delay:1s;"
    >
    </div>

    <!-- Card principal -->
    <div
      class="card-glass rounded-2xl w-full max-w-sm sm:max-w-md relative animate-in"
      style="animation-delay:0.1s"
    >
      <!-- Esquinas decorativas -->
      <div class="corner-tl rounded-tl-sm"></div>
      <div class="corner-br rounded-br-sm"></div>

      <!-- Header con logo -->
      <div class="pt-10 pb-8 px-8 sm:px-10 text-center">
        <!-- Logo -->
        <div
          class="flex justify-center mb-5 animate-in"
          style="animation-delay:0.2s"
        >
          <img
            src="data:image/png;base64,"
            alt="QorySol Logo"
            class="logo-img h-20 sm:h-24 w-auto object-contain"
          />
        </div>

        <!-- Nombre -->
        <h1
          class="title-brand text-3xl sm:text-4xl font-bold animate-in"
          style="animation-delay:0.3s"
        >
          QorySol
        </h1>

        <!-- Subtítulo -->
        <p
          class="subtitle text-xs mt-2 animate-in"
          style="animation-delay:0.4s"
        >
          Potencia tu negocio
        </p>

        <!-- Línea divisora -->
        <div
          class="divider-line h-px mt-6 mx-auto w-3/4 animate-in"
          style="animation-delay:0.5s"
        >
        </div>
      </div>

      <!-- Formulario -->
      <div class="px-8 sm:px-10 pb-10">
        <form
          id="loginForm"
          novalidate
        >
          <!-- Campo DNI -->
          <div
            class="mb-5 animate-in"
            style="animation-delay:0.5s"
          >
            <label
              for="dni"
              class="label-text block mb-2"
            >
              DNI (usuario)
            </label>
            <div class="relative">
              <span class="icon-wrap absolute left-4 top-1/2 -translate-y-1/2">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <rect
                    x="3"
                    y="4"
                    width="18"
                    height="16"
                    rx="2"
                    stroke="currentColor"
                    fill="none"
                  >
                  </rect>
                  <circle
                    cx="9"
                    cy="10"
                    r="2"
                    stroke="currentColor"
                    fill="none"
                  >
                  </circle>
                  <path
                    d="M6 15c0-1.5 1.3-2.5 3-2.5s3 1 3 2.5"
                    stroke="currentColor"
                  >
                  </path>
                  <path
                    d="M15 9h3M15 12h2"
                    stroke="currentColor"
                    stroke-linecap="round"
                  >
                  </path>
                </svg>
              </span>
              <input
                type="text"
                id="dni"
                name="dni"
                placeholder="12345678"
                maxlength="8"
                class="input-field w-full pl-11 pr-4 py-3.5 rounded-xl text-sm"
                inputmode="numeric"
                pattern="\d{8}"
              />
            </div>
            <p
              id="dniError"
              class="text-red-400 text-xs mt-1.5 hidden pl-1"
            >
              Ingresa tu DNI de 8 dígitos
            </p>
          </div>

          <!-- Campo Contraseña -->
          <div
            class="mb-7 animate-in"
            style="animation-delay:0.6s"
          >
            <label
              for="password"
              class="label-text block mb-2"
            >
              Contraseña (4 dígitos)
            </label>
            <div class="relative">
              <span class="icon-wrap absolute left-4 top-1/2 -translate-y-1/2">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <rect
                    x="5"
                    y="11"
                    width="14"
                    height="10"
                    rx="2"
                    stroke="currentColor"
                    fill="none"
                  >
                  </rect>
                  <path
                    d="M8 11V7a4 4 0 118 0v4"
                    stroke="currentColor"
                    stroke-linecap="round"
                  >
                  </path>
                </svg>
              </span>
              <input
                type="password"
                id="password"
                name="password"
                placeholder="••••"
                maxlength="4"
                class="input-field w-full pl-11 pr-12 py-3.5 rounded-xl text-sm tracking-widest"
                inputmode="numeric"
                pattern="\d{4}"
              />
              <button
                type="button"
                id="togglePass"
                class="icon-wrap absolute right-4 top-1/2 -translate-y-1/2 hover:text-gold-400 transition-colors"
                tabindex="-1"
                title="Mostrar/ocultar"
              >
                <svg
                  id="eyeIcon"
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                    stroke="currentColor"
                  >
                  </path>
                  <circle
                    cx="12"
                    cy="12"
                    r="3"
                    stroke="currentColor"
                  >
                  </circle>
                </svg>
              </button>
            </div>
            <p
              id="passError"
              class="text-red-400 text-xs mt-1.5 hidden pl-1"
            >
              Contraseña de 4 dígitos requerida
            </p>
          </div>

          <!-- Botón Ingresar -->
          <button
            type="submit"
            id="submitBtn"
            class="btn-login w-full py-4 rounded-xl text-sm flex items-center justify-center gap-2.5 animate-in"
            style="animation-delay:0.7s"
          >
            <svg
              id="arrowIcon"
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
              </path>
              <polyline
                points="10 17 15 12 10 7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
              </polyline>
              <line
                x1="15"
                y1="12"
                x2="3"
                y2="12"
                stroke-linecap="round"
              >
              </line>
            </svg>
            <span id="btnText">Ingresar</span>
          </button>
        </form>

        <!-- Demo hint -->
        <div
          class="demo-badge mt-6 rounded-lg px-4 py-2.5 flex items-center gap-2.5 animate-in"
          style="animation-delay:0.8s"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3.5 h-3.5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            style="color:rgba(212,160,23,0.5)"
          >
            <path
              d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
              stroke="currentColor"
            >
            </path>
          </svg>
          <span>
            Demo: DNI <strong style="color:rgba(212,160,23,0.7)">
              12345678
            </strong> · contraseña <strong style="color:rgba(212,160,23,0.7)">
              1234
            </strong>
          </span>
        </div>
      </div>
    </div>

    <script>
      const togglePass = document.getElementById(
        "togglePass",
      ) as HTMLButtonElement;
      const passInput = document.getElementById("password") as HTMLInputElement;
      const eyeIcon = document.getElementById("eyeIcon") as HTMLElement;
      const dniInput = document.getElementById("dni") as HTMLInputElement;
      const form = document.getElementById("loginForm") as HTMLFormElement;
      const btnText = document.getElementById("btnText") as HTMLElement;
      const arrowIcon = document.getElementById("arrowIcon") as HTMLElement;
      const submitBtn = document.getElementById(
        "submitBtn",
      ) as HTMLButtonElement;
      const dniErr = document.getElementById("dniError") as HTMLElement;
      const passErr = document.getElementById("passError") as HTMLElement;

      // ── Toggle contraseña ──────────────────────────────
      togglePass.addEventListener("click", () => {
        const isPass = passInput.type === "password";
        passInput.type = isPass ? "text" : "password";
        eyeIcon.innerHTML = isPass
          ? `<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24" stroke="currentColor" stroke-linecap="round"/><line x1="1" y1="1" x2="23" y2="23" stroke="currentColor" stroke-linecap="round"/>`
          : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor"/><circle cx="12" cy="12" r="3" stroke="currentColor"/>`;
      });

      // ── Solo dígitos ───────────────────────────────────
      dniInput.addEventListener("input", () => {
        dniInput.value = dniInput.value.replace(/\D/g, "").slice(0, 8);
      });
      passInput.addEventListener("input", () => {
        passInput.value = passInput.value.replace(/\D/g, "").slice(0, 4);
      });

      // ── Form submit ────────────────────────────────────
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const dni = dniInput.value;
        const pass = passInput.value;

        let valid = true;
        dniErr.classList.add("hidden");
        passErr.classList.add("hidden");

        if (!/^\d{8}$/.test(dni)) {
          dniErr.classList.remove("hidden");
          dniInput.classList.add("shake");
          setTimeout(() => dniInput.classList.remove("shake"), 400);
          valid = false;
        }
        if (!/^\d{4}$/.test(pass)) {
          passErr.classList.remove("hidden");
          passInput.classList.add("shake");
          setTimeout(() => passInput.classList.remove("shake"), 400);
          valid = false;
        }

        if (!valid) return;

        // Estado de carga
        btnText.textContent = "Verificando...";
        arrowIcon.innerHTML = `<path d="M12 2a10 10 0 100 20A10 10 0 0012 2z" stroke="currentColor" opacity="0.2"/><path d="M12 2a10 10 0 0110 10" stroke="currentColor" stroke-linecap="round"><animateTransform attributeName="transform" type="rotate" dur="0.8s" from="0 12 12" to="360 12 12" repeatCount="indefinite"/></path>`;

        setTimeout(() => {
          if (dni === "12345678" && pass === "1234") {
            btnText.textContent = "✓ Bienvenido";
            submitBtn.style.background =
              "linear-gradient(135deg, #166534, #16a34a)";
            submitBtn.style.color = "#fff";
          } else {
            btnText.textContent = "Ingresar";
            arrowIcon.innerHTML = `<path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4" stroke-linecap="round" stroke-linejoin="round"/><polyline points="10 17 15 12 10 7" stroke-linecap="round" stroke-linejoin="round"/><line x1="15" y1="12" x2="3" y2="12" stroke-linecap="round"/>`;
            dniErr.textContent =
              "Credenciales incorrectas. Usa los datos de demo.";
            dniErr.classList.remove("hidden");
            submitBtn.classList.add("shake");
            setTimeout(() => submitBtn.classList.remove("shake"), 400);
          }
        }, 1200);
      });
    </script>
  </body>
</html>
